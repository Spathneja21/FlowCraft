<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>FlowCraft — Workspace</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=DM+Mono:ital,wght@0,300;0,400;0,500;1,300&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:        #0d0f0e;
      --bg2:       #131614;
      --bg3:       #1a1d1b;
      --bg4:       #1f2420;
      --border:    #2a2e2b;
      --border2:   #363c37;
      --border3:   #424a43;
      --text:      #e8ede9;
      --text2:     #8a9489;
      --text3:     #4d5a4e;
      --accent:    #5cdb8f;
      --accent2:   #3db870;
      --accent-bg: #0e2318;
      --red:       #e05c5c;
      --red-bg:    #2a1212;
      --mono:      'DM Mono', monospace;
      --display:   'Syne', sans-serif;
    }

    html { scroll-behavior: smooth; }

    body {
      min-height: 100vh;
      background: var(--bg);
      color: var(--text);
      font-family: var(--mono);
      overflow-x: hidden;
    }

    /* ── Grid background ── */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(var(--border) 1px, transparent 1px),
        linear-gradient(90deg, var(--border) 1px, transparent 1px),
        linear-gradient(var(--bg2) 1px, transparent 1px),
        linear-gradient(90deg, var(--bg2) 1px, transparent 1px);
      background-size: 80px 80px, 80px 80px, 16px 16px, 16px 16px;
      opacity: 0.35;
      z-index: 0;
      pointer-events: none;
    }

    body::after {
      content: '';
      position: fixed;
      inset: 0;
      background: radial-gradient(ellipse 100% 60% at 50% 0%, transparent 50%, var(--bg) 100%);
      z-index: 0;
      pointer-events: none;
    }

    /* ── Topbar ── */
    .topbar {
      position: sticky;
      top: 0;
      z-index: 50;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 32px;
      height: 56px;
      background: rgba(13, 15, 14, 0.85);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
    }

    .topbar-left {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .logo-mark {
      width: 30px;
      height: 30px;
      border: 1px solid var(--accent);
      border-radius: 2px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .logo-mark svg { width: 17px; height: 17px; }

    .logo-name {
      font-family: var(--display);
      font-size: 17px;
      font-weight: 700;
      color: var(--text);
      letter-spacing: -0.01em;
    }

    .logo-name span { color: var(--accent); }

    .topbar-sep {
      width: 1px;
      height: 18px;
      background: var(--border2);
      margin: 0 4px;
    }

    .topbar-route {
      font-size: 11px;
      color: var(--text3);
      letter-spacing: 0.1em;
    }

    .topbar-right {
      display: flex;
      align-items: center;
      gap: 16px;
    }

    .user-chip {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 5px 10px;
      border: 1px solid var(--border2);
      border-radius: 2px;
      font-size: 11px;
      color: var(--text2);
      letter-spacing: 0.06em;
    }

    .user-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--accent);
      animation: pulse-dot 2.5s ease-in-out infinite;
    }

    @keyframes pulse-dot {
      0%, 100% { opacity: 1; }
      50%       { opacity: 0.25; }
    }

    .btn-signout {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--text3);
      background: none;
      border: 1px solid var(--border);
      border-radius: 2px;
      padding: 5px 12px;
      cursor: pointer;
      letter-spacing: 0.08em;
      transition: color 0.15s, border-color 0.15s;
    }

    .btn-signout:hover {
      color: var(--red);
      border-color: var(--red);
    }

    /* ── Page content ── */
    .page {
      position: relative;
      z-index: 1;
      max-width: 1100px;
      margin: 0 auto;
      padding: 52px 32px 80px;
    }

    /* ── Section header ── */
    .section-head {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      margin-bottom: 32px;
      animation: fade-up 0.4s both;
    }

    .section-title-group {}

    .section-eyebrow {
      font-size: 10px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--text3);
      margin-bottom: 6px;
    }

    .section-title {
      font-family: var(--display);
      font-size: 26px;
      font-weight: 700;
      color: var(--text);
      letter-spacing: -0.02em;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .board-count {
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 400;
      color: var(--text3);
      padding: 2px 8px;
      border: 1px solid var(--border2);
      border-radius: 2px;
      letter-spacing: 0.06em;
    }

    /* ── New board button ── */
    .btn-new {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 10px 20px;
      background: var(--accent);
      color: #050e08;
      border: none;
      border-radius: 2px;
      font-family: var(--display);
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      cursor: pointer;
      transition: background 0.15s, transform 0.1s;
      white-space: nowrap;
    }

    .btn-new:hover { background: var(--accent2); }
    .btn-new:active { transform: scale(0.97); }

    .btn-new svg { flex-shrink: 0; }

    /* ── Boards grid ── */
    .boards-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 16px;
    }

    /* ── Board card ── */
    .board-card {
      background: var(--bg2);
      border: 1px solid var(--border);
      border-radius: 2px;
      overflow: hidden;
      cursor: pointer;
      transition: border-color 0.15s, transform 0.15s;
      animation: fade-up 0.4s both;
      position: relative;
    }

    .board-card:hover {
      border-color: var(--border3);
      transform: translateY(-2px);
    }

    .board-card:hover .card-preview {
      opacity: 0.9;
    }

    .board-card:hover .card-open-hint {
      opacity: 1;
    }

    /* Preview area with mini canvas doodle */
    .card-preview {
      height: 130px;
      background: var(--bg3);
      border-bottom: 1px solid var(--border);
      position: relative;
      overflow: hidden;
      transition: opacity 0.15s;
    }

    .card-preview svg {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
    }

    .card-open-hint {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(13,15,14,0.55);
      opacity: 0;
      transition: opacity 0.15s;
      font-size: 11px;
      letter-spacing: 0.14em;
      color: var(--accent);
      text-transform: uppercase;
    }

    .card-body {
      padding: 14px 16px 12px;
    }

    .card-name-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
      margin-bottom: 6px;
    }

    .card-name {
      font-family: var(--display);
      font-size: 14px;
      font-weight: 600;
      color: var(--text);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      flex: 1;
      min-width: 0;
    }

    .card-name-input {
      font-family: var(--display);
      font-size: 14px;
      font-weight: 600;
      color: var(--text);
      background: var(--bg3);
      border: 1px solid var(--accent);
      border-radius: 2px;
      padding: 2px 6px;
      outline: none;
      width: 100%;
      display: none;
    }

    .card-name-input.active { display: block; }
    .card-name.hidden { display: none; }

    .card-actions {
      display: flex;
      gap: 4px;
      flex-shrink: 0;
      opacity: 0;
      transition: opacity 0.15s;
    }

    .board-card:hover .card-actions { opacity: 1; }

    .action-btn {
      width: 24px;
      height: 24px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--bg4);
      border: 1px solid var(--border2);
      border-radius: 2px;
      cursor: pointer;
      transition: border-color 0.12s, background 0.12s;
    }

    .action-btn:hover { border-color: var(--border3); background: var(--bg3); }
    .action-btn.del:hover { border-color: var(--red); background: var(--red-bg); }
    .action-btn.del:hover svg path { stroke: var(--red); }
    .action-btn svg { pointer-events: none; }

    .card-meta {
      font-size: 10px;
      color: var(--text3);
      letter-spacing: 0.06em;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .meta-sep { opacity: 0.4; }

    /* ── Empty state ── */
    .empty-state {
      grid-column: 1 / -1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 14px;
      padding: 80px 20px;
      border: 1px dashed var(--border2);
      border-radius: 2px;
      animation: fade-up 0.4s 0.1s both;
    }

    .empty-icon {
      width: 48px;
      height: 48px;
      border: 1px solid var(--border2);
      border-radius: 2px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .empty-label {
      font-family: var(--display);
      font-size: 15px;
      font-weight: 600;
      color: var(--text2);
    }

    .empty-sub {
      font-size: 11px;
      color: var(--text3);
      letter-spacing: 0.06em;
      text-align: center;
      line-height: 1.7;
    }

    .btn-empty-new {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-top: 4px;
      padding: 10px 22px;
      background: var(--accent-bg);
      color: var(--accent);
      border: 1px solid var(--accent);
      border-radius: 2px;
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.1em;
      cursor: pointer;
      transition: background 0.15s;
    }

    .btn-empty-new:hover { background: #122d1e; }

    /* ── Modal overlay (new board) ── */
    .modal-backdrop {
      position: fixed;
      inset: 0;
      z-index: 200;
      background: rgba(7, 9, 8, 0.75);
      backdrop-filter: blur(4px);
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.2s;
    }

    .modal-backdrop.open {
      opacity: 1;
      pointer-events: all;
    }

    .modal {
      width: 100%;
      max-width: 380px;
      background: var(--bg2);
      border: 1px solid var(--border2);
      border-radius: 2px;
      overflow: hidden;
      transform: translateY(16px);
      transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
    }

    .modal-backdrop.open .modal {
      transform: translateY(0);
    }

    .modal-header {
      padding: 20px 24px 16px;
      border-bottom: 1px solid var(--border);
      position: relative;
    }

    .modal-header::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 2px;
      background: var(--accent);
    }

    .modal-title {
      font-family: var(--display);
      font-size: 15px;
      font-weight: 700;
      color: var(--text);
    }

    .modal-body { padding: 20px 24px; }

    .modal-label {
      font-size: 10px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--text3);
      margin-bottom: 8px;
      display: block;
    }

    .modal-input {
      width: 100%;
      background: var(--bg3);
      border: 1px solid var(--border2);
      border-radius: 2px;
      color: var(--text);
      font-family: var(--mono);
      font-size: 13px;
      padding: 10px 14px;
      outline: none;
      transition: border-color 0.15s;
    }

    .modal-input:focus { border-color: var(--accent); }

    .modal-footer {
      padding: 14px 24px;
      border-top: 1px solid var(--border);
      display: flex;
      gap: 10px;
      justify-content: flex-end;
    }

    .btn-cancel {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--text3);
      background: none;
      border: 1px solid var(--border2);
      border-radius: 2px;
      padding: 8px 16px;
      cursor: pointer;
      letter-spacing: 0.08em;
      transition: color 0.12s, border-color 0.12s;
    }

    .btn-cancel:hover { color: var(--text2); border-color: var(--border3); }

    .btn-create {
      font-family: var(--display);
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #050e08;
      background: var(--accent);
      border: none;
      border-radius: 2px;
      padding: 8px 20px;
      cursor: pointer;
      transition: background 0.12s;
    }

    .btn-create:hover { background: var(--accent2); }

    /* ── Delete confirm ── */
    .delete-confirm {
      position: absolute;
      top: 0; left: 0; right: 0; bottom: 0;
      background: var(--red-bg);
      border: 1px solid var(--red);
      border-radius: 2px;
      display: none;
      align-items: center;
      justify-content: center;
      gap: 10px;
      z-index: 10;
      padding: 12px;
    }

    .delete-confirm.show { display: flex; }

    .delete-confirm span {
      font-size: 11px;
      color: var(--red);
      letter-spacing: 0.06em;
      flex: 1;
      min-width: 0;
    }

    .confirm-yes, .confirm-no {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.08em;
      border-radius: 2px;
      padding: 4px 10px;
      cursor: pointer;
      border: 1px solid;
      white-space: nowrap;
    }

    .confirm-yes { color: var(--red); border-color: var(--red); background: transparent; }
    .confirm-yes:hover { background: var(--red); color: var(--bg); }
    .confirm-no  { color: var(--text3); border-color: var(--border2); background: transparent; }
    .confirm-no:hover  { color: var(--text2); }

    /* ── Animations ── */
    @keyframes fade-up {
      from { opacity: 0; transform: translateY(12px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .board-card.removing {
      animation: card-out 0.25s forwards;
    }

    @keyframes card-out {
      to { opacity: 0; transform: scale(0.93); }
    }
  </style>
</head>
<body>

  <!-- Topbar -->
  <header class="topbar">
    <div class="topbar-left">
      <div class="logo-mark">
        <svg viewBox="0 0 20 20" fill="none">
          <rect x="1" y="1" width="7" height="7" rx="1" stroke="#5cdb8f" stroke-width="1.2"/>
          <rect x="12" y="1" width="7" height="7" rx="1" stroke="#5cdb8f" stroke-width="1.2"/>
          <rect x="6.5" y="12" width="7" height="7" rx="1" stroke="#5cdb8f" stroke-width="1.2"/>
          <line x1="4.5" y1="8" x2="4.5" y2="15.5" stroke="#5cdb8f" stroke-width="1" stroke-opacity="0.5"/>
          <line x1="15.5" y1="8" x2="15.5" y2="15.5" stroke="#5cdb8f" stroke-width="1" stroke-opacity="0.5"/>
          <line x1="4.5" y1="15.5" x2="10" y2="15.5" stroke="#5cdb8f" stroke-width="1" stroke-opacity="0.5"/>
          <line x1="15.5" y1="15.5" x2="10" y2="15.5" stroke="#5cdb8f" stroke-width="1" stroke-opacity="0.5"/>
        </svg>
      </div>
      <div class="logo-name">Flow<span>Craft</span></div>
      <div class="topbar-sep"></div>
      <div class="topbar-route">workspace</div>
    </div>
    <div class="topbar-right">
      <div class="user-chip">
        <span class="user-dot"></span>
        s_pathneja21
      </div>
      <button class="btn-signout" onclick="handleSignOut()">sign out</button>
    </div>
  </header>

  <!-- Main page -->
  <main class="page">
    <div class="section-head">
      <div class="section-title-group">
        <div class="section-eyebrow">// my workspace</div>
        <div class="section-title">
          Boards
          <span class="board-count" id="board-count">0</span>
        </div>
      </div>
      <button class="btn-new" onclick="openNewBoardModal()">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
          <line x1="7" y1="1" x2="7" y2="13" stroke="#050e08" stroke-width="1.8" stroke-linecap="round"/>
          <line x1="1" y1="7" x2="13" y2="7" stroke="#050e08" stroke-width="1.8" stroke-linecap="round"/>
        </svg>
        New board
      </button>
    </div>

    <div class="boards-grid" id="boards-grid">
      <!-- Cards injected by JS -->
    </div>
  </main>

  <!-- New board modal -->
  <div class="modal-backdrop" id="modal-backdrop" onclick="handleBackdropClick(event)">
    <div class="modal">
      <div class="modal-header">
        <div class="modal-title">New board</div>
      </div>
      <div class="modal-body">
        <label class="modal-label" for="board-name-input">Board name</label>
        <input
          class="modal-input"
          id="board-name-input"
          type="text"
          placeholder="e.g. User flow, System design…"
          maxlength="48"
          autocomplete="off"
        />
      </div>
      <div class="modal-footer">
        <button class="btn-cancel" onclick="closeModal()">Cancel</button>
        <button class="btn-create" onclick="createBoard()">Create board</button>
      </div>
    </div>
  </div>

  <script>
    /* ─────────────────────────────────────────────
       Storage helpers
    ───────────────────────────────────────────── */
    const STORAGE_KEY = 'flowcraft_boards';

    function loadBoards() {
      try {
        return JSON.parse(localStorage.getItem(STORAGE_KEY)) || [];
      } catch { return []; }
    }

    function saveBoards(boards) {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(boards));
    }

    function generateId() {
      return 'board_' + Date.now() + '_' + Math.random().toString(36).slice(2, 7);
    }

    function formatDate(ts) {
      const d = new Date(ts);
      const now = new Date();
      const diff = (now - d) / 1000;
      if (diff < 60)    return 'just now';
      if (diff < 3600)  return Math.floor(diff / 60) + 'm ago';
      if (diff < 86400) return Math.floor(diff / 3600) + 'h ago';
      return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short' });
    }

    /* ─────────────────────────────────────────────
       Minimal SVG preview thumbnails — a few shapes
       each board gets a deterministic-ish pattern
    ───────────────────────────────────────────── */
    const PREVIEW_PATTERNS = [
      `<rect x="20" y="28" width="72" height="32" rx="3" fill="none" stroke="#363c37" stroke-width="1"/>
       <text x="56" y="49" text-anchor="middle" font-family="DM Mono" font-size="8" fill="#4d5a4e">start</text>
       <line x1="92" y1="44" x2="116" y2="44" stroke="#363c37" stroke-width="1" marker-end="url(#arr)"/>
       <rect x="116" y="28" width="80" height="32" rx="3" fill="none" stroke="#5cdb8f" stroke-width="1" stroke-opacity="0.5"/>
       <text x="156" y="49" text-anchor="middle" font-family="DM Mono" font-size="8" fill="#4d5a4e">process</text>
       <line x1="156" y1="60" x2="156" y2="80" stroke="#363c37" stroke-width="1" marker-end="url(#arr)"/>
       <polygon points="156,80 136,104 176,104" fill="none" stroke="#363c37" stroke-width="1"/>
       <text x="156" y="97" text-anchor="middle" font-family="DM Mono" font-size="7" fill="#4d5a4e">decision</text>
       <line x1="176" y1="92" x2="210" y2="92" stroke="#363c37" stroke-width="1" marker-end="url(#arr)"/>
       <rect x="210" y="76" width="60" height="32" rx="3" fill="none" stroke="#363c37" stroke-width="1"/>
       <text x="240" y="97" text-anchor="middle" font-family="DM Mono" font-size="8" fill="#4d5a4e">end</text>`,

      `<ellipse cx="80" cy="44" rx="48" ry="22" fill="none" stroke="#363c37" stroke-width="1"/>
       <text x="80" y="49" text-anchor="middle" font-family="DM Mono" font-size="8" fill="#4d5a4e">init</text>
       <line x1="80" y1="66" x2="80" y2="80" stroke="#363c37" stroke-width="1" marker-end="url(#arr)"/>
       <rect x="32" y="80" width="96" height="30" rx="3" fill="none" stroke="#5cdb8f" stroke-width="1" stroke-opacity="0.4"/>
       <text x="80" y="100" text-anchor="middle" font-family="DM Mono" font-size="7" fill="#4d5a4e">validate input</text>
       <path d="M128 95 Q190 95 190 55 Q190 20 140 20 L120 20" fill="none" stroke="#363c37" stroke-width="1" stroke-dasharray="3 2" marker-end="url(#arr)"/>`,

      `<rect x="16" y="20" width="64" height="28" rx="3" fill="none" stroke="#363c37" stroke-width="1"/>
       <text x="48" y="39" text-anchor="middle" font-family="DM Mono" font-size="7" fill="#4d5a4e">frontend</text>
       <line x1="80" y1="34" x2="108" y2="34" stroke="#5cdb8f" stroke-width="1" stroke-opacity="0.5" marker-end="url(#arr)"/>
       <rect x="108" y="20" width="64" height="28" rx="3" fill="none" stroke="#5cdb8f" stroke-width="1" stroke-opacity="0.5"/>
       <text x="140" y="39" text-anchor="middle" font-family="DM Mono" font-size="7" fill="#4d5a4e">API layer</text>
       <line x1="172" y1="34" x2="200" y2="34" stroke="#363c37" stroke-width="1" marker-end="url(#arr)"/>
       <rect x="200" y="20" width="64" height="28" rx="3" fill="none" stroke="#363c37" stroke-width="1"/>
       <text x="232" y="39" text-anchor="middle" font-family="DM Mono" font-size="7" fill="#4d5a4e">database</text>
       <line x1="80" y1="76" x2="240" y2="76" stroke="#363c37" stroke-width="0.5" stroke-dasharray="2 2"/>
       <rect x="100" y="64" width="80" height="24" rx="3" fill="none" stroke="#363c37" stroke-width="1"/>
       <text x="140" y="80" text-anchor="middle" font-family="DM Mono" font-size="7" fill="#4d5a4e">middleware</text>`,

      `<rect x="30" y="16" width="76" height="28" rx="14" fill="none" stroke="#363c37" stroke-width="1"/>
       <text x="68" y="35" text-anchor="middle" font-family="DM Mono" font-size="7" fill="#4d5a4e">user login</text>
       <line x1="68" y1="44" x2="68" y2="60" stroke="#363c37" stroke-width="1" marker-end="url(#arr)"/>
       <polygon points="68,60 48,88 88,88" fill="none" stroke="#5cdb8f" stroke-width="1" stroke-opacity="0.6"/>
       <text x="68" y="79" text-anchor="middle" font-family="DM Mono" font-size="6" fill="#4d5a4e">valid?</text>
       <line x1="48" y1="74" x2="16" y2="74" stroke="#363c37" stroke-width="1" marker-end="url(#arr)"/>
       <rect x="16" y="88" width="56" height="24" rx="3" fill="none" stroke="#e05c5c" stroke-width="1" stroke-opacity="0.5"/>
       <text x="44" y="105" text-anchor="middle" font-family="DM Mono" font-size="6" fill="#4d5a4e">error</text>
       <line x1="88" y1="74" x2="210" y2="74" stroke="#363c37" stroke-width="1" marker-end="url(#arr)"/>
       <rect x="176" y="60" width="64" height="28" rx="3" fill="none" stroke="#363c37" stroke-width="1"/>
       <text x="208" y="79" text-anchor="middle" font-family="DM Mono" font-size="7" fill="#4d5a4e">dashboard</text>`,
    ];

    function getPreviewSVG(index) {
      const pattern = PREVIEW_PATTERNS[index % PREVIEW_PATTERNS.length];
      return `<svg viewBox="0 0 280 130" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <marker id="arr" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="5" markerHeight="5" orient="auto-start-reverse">
            <path d="M2 2L8 5L2 8" fill="none" stroke="#363c37" stroke-width="1.5"/>
          </marker>
        </defs>
        ${pattern}
      </svg>`;
    }

    /* ─────────────────────────────────────────────
       Render
    ───────────────────────────────────────────── */
    function render() {
      const boards = loadBoards();
      const grid   = document.getElementById('boards-grid');
      const count  = document.getElementById('board-count');

      count.textContent = boards.length;
      grid.innerHTML = '';

      if (boards.length === 0) {
        grid.innerHTML = `
          <div class="empty-state">
            <div class="empty-icon">
              <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
                <rect x="1" y="1" width="8" height="8" rx="1.5" stroke="#4d5a4e" stroke-width="1.2"/>
                <rect x="13" y="1" width="8" height="8" rx="1.5" stroke="#4d5a4e" stroke-width="1.2"/>
                <rect x="7" y="13" width="8" height="8" rx="1.5" stroke="#4d5a4e" stroke-width="1.2"/>
                <line x1="5" y1="9" x2="5" y2="17" stroke="#4d5a4e" stroke-width="1" stroke-opacity="0.5"/>
                <line x1="17" y1="9" x2="17" y2="17" stroke="#4d5a4e" stroke-width="1" stroke-opacity="0.5"/>
                <line x1="5" y1="17" x2="11" y2="17" stroke="#4d5a4e" stroke-width="1" stroke-opacity="0.5"/>
                <line x1="17" y1="17" x2="11" y2="17" stroke="#4d5a4e" stroke-width="1" stroke-opacity="0.5"/>
              </svg>
            </div>
            <div class="empty-label">No boards yet</div>
            <div class="empty-sub">Create your first board to start<br/>building flowcharts.</div>
            <button class="btn-empty-new" onclick="openNewBoardModal()">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                <line x1="6" y1="1" x2="6" y2="11" stroke="#5cdb8f" stroke-width="1.6" stroke-linecap="round"/>
                <line x1="1" y1="6" x2="11" y2="6" stroke="#5cdb8f" stroke-width="1.6" stroke-linecap="round"/>
              </svg>
              Create first board
            </button>
          </div>`;
        return;
      }

      boards.forEach((board, i) => {
        const card = document.createElement('div');
        card.className = 'board-card';
        card.style.animationDelay = (i * 0.05) + 's';
        card.dataset.id = board.id;

        card.innerHTML = `
          <div class="card-preview">
            ${getPreviewSVG(board.previewIndex ?? i)}
            <div class="card-open-hint">Open board →</div>
          </div>
          <div class="card-body">
            <div class="card-name-row">
              <div class="card-name" id="name-${board.id}">${escHtml(board.name)}</div>
              <input class="card-name-input" id="input-${board.id}" value="${escHtml(board.name)}" maxlength="48"/>
              <div class="card-actions">
                <div class="action-btn" title="Rename" onclick="startRename('${board.id}', event)">
                  <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                    <path d="M1 9.5L3.5 10L10 3.5L8.5 2L2 8.5L1 9.5Z" stroke="#8a9489" stroke-width="1" fill="none"/>
                    <line x1="7.5" y1="2.5" x2="9.5" y2="4.5" stroke="#8a9489" stroke-width="1"/>
                  </svg>
                </div>
                <div class="action-btn del" title="Delete" onclick="askDelete('${board.id}', event)">
                  <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                    <path d="M2 3H10M4.5 3V2H7.5V3M4 5V9M8 5V9M3 3L3.5 10H8.5L9 3" stroke="#8a9489" stroke-width="1" stroke-linecap="round"/>
                  </svg>
                </div>
              </div>
            </div>
            <div class="card-meta">
              <span>edited ${formatDate(board.updatedAt)}</span>
              <span class="meta-sep">·</span>
              <span>${board.nodeCount ?? 0} nodes</span>
            </div>
          </div>
          <div class="delete-confirm" id="del-confirm-${board.id}">
            <span>Delete "${escHtml(board.name)}"?</span>
            <button class="confirm-no"  onclick="cancelDelete('${board.id}', event)">no</button>
            <button class="confirm-yes" onclick="confirmDelete('${board.id}', event)">yes, delete</button>
          </div>`;

        /* Open board on click (but not on action buttons) */
        card.addEventListener('click', (e) => {
          if (e.target.closest('.card-actions') ||
              e.target.closest('.delete-confirm') ||
              e.target.closest('.card-name-input')) return;
          openBoard(board.id);
        });

        /* Rename on Enter/Escape */
        const inp = card.querySelector(`#input-${board.id}`);
        inp.addEventListener('keydown', (e) => {
          if (e.key === 'Enter')  commitRename(board.id);
          if (e.key === 'Escape') cancelRename(board.id);
        });
        inp.addEventListener('blur', () => commitRename(board.id));

        grid.appendChild(card);
      });
    }

    /* ─────────────────────────────────────────────
       Board actions
    ───────────────────────────────────────────── */
    function openBoard(id) {
      /* In your full build, navigate to the canvas page:
         window.location.href = `/board.html?id=${id}`;
         For now we show a console message + brief flash */
      const card = document.querySelector(`[data-id="${id}"]`);
      if (card) {
        card.style.borderColor = 'var(--accent)';
        setTimeout(() => { card.style.borderColor = ''; }, 600);
      }
      console.log('Opening board:', id);
      // TODO: window.location.href = `/board.html?id=${id}`;
    }

    function startRename(id, e) {
      e.stopPropagation();
      const nameEl  = document.getElementById('name-' + id);
      const inputEl = document.getElementById('input-' + id);
      nameEl.classList.add('hidden');
      inputEl.classList.add('active');
      inputEl.focus();
      inputEl.select();
    }

    function commitRename(id) {
      const inputEl = document.getElementById('input-' + id);
      if (!inputEl || !inputEl.classList.contains('active')) return;
      const newName = inputEl.value.trim() || 'Untitled board';
      const boards  = loadBoards();
      const board   = boards.find(b => b.id === id);
      if (board) {
        board.name = newName;
        board.updatedAt = Date.now();
        saveBoards(boards);
      }
      render();
    }

    function cancelRename(id) {
      render();
    }

    function askDelete(id, e) {
      e.stopPropagation();
      document.getElementById('del-confirm-' + id).classList.add('show');
    }

    function cancelDelete(id, e) {
      e.stopPropagation();
      document.getElementById('del-confirm-' + id).classList.remove('show');
    }

    function confirmDelete(id, e) {
      e.stopPropagation();
      const card = document.querySelector(`[data-id="${id}"]`);
      card.classList.add('removing');
      card.addEventListener('animationend', () => {
        const boards = loadBoards().filter(b => b.id !== id);
        saveBoards(boards);
        render();
      }, { once: true });
    }

    /* ─────────────────────────────────────────────
       New board modal
    ───────────────────────────────────────────── */
    function openNewBoardModal() {
      const backdrop = document.getElementById('modal-backdrop');
      const input    = document.getElementById('board-name-input');
      input.value = '';
      backdrop.classList.add('open');
      setTimeout(() => input.focus(), 250);
    }

    function closeModal() {
      document.getElementById('modal-backdrop').classList.remove('open');
    }

    function handleBackdropClick(e) {
      if (e.target === document.getElementById('modal-backdrop')) closeModal();
    }

    function createBoard() {
      const input = document.getElementById('board-name-input');
      const name  = input.value.trim() || 'Untitled board';
      const boards = loadBoards();

      const newBoard = {
        id:           generateId(),
        name:         name,
        createdAt:    Date.now(),
        updatedAt:    Date.now(),
        nodeCount:    0,
        previewIndex: boards.length,
      };

      boards.unshift(newBoard);
      saveBoards(boards);
      closeModal();
      render();

      /* Scroll to top so the new card is visible */
      window.scrollTo({ top: 0, behavior: 'smooth' });

      /* Redirect to canvas (when built):
         window.location.href = `/board.html?id=${newBoard.id}`; */
    }

    /* Enter key in modal */
    document.getElementById('board-name-input')
      .addEventListener('keydown', e => {
        if (e.key === 'Enter') createBoard();
        if (e.key === 'Escape') closeModal();
      });

    /* Escape key anywhere */
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape') closeModal();
    });

    /* ─────────────────────────────────────────────
       Sign out
    ───────────────────────────────────────────── */
    function handleSignOut() {
      /* In full build: clear session and redirect to login */
      window.location.href = 'index.html';
    }

    /* ─────────────────────────────────────────────
       Utility
    ───────────────────────────────────────────── */
    function escHtml(str) {
      return String(str)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }

    /* ─────────────────────────────────────────────
       Init
    ───────────────────────────────────────────── */
    render();
  </script>
</body>
</html>